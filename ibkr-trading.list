# Quantumult X filter rules for IBKR / thinkorswim trading traffic
# Policy names:
# - DIRECT: mainland China IBKR domains
# - TRADING: global IBKR / thinkorswim / Schwab traffic
#
# If your Quantumult X policy group uses a different name, replace TRADING
# with the target policy or policy group name.

# IBKR China
HOST-SUFFIX,ibkr.com.cn,DIRECT
HOST-SUFFIX,ibllc.com.cn,DIRECT

# IBKR
HOST-SUFFIX,ibkr.com,TRADING
HOST-SUFFIX,ibllc.com,TRADING
HOST-SUFFIX,ibkr.com.hk,TRADING
HOST-SUFFIX,ibkr.com.au,TRADING
HOST-SUFFIX,ibcdn.com,TRADING
HOST-SUFFIX,iblink.com,TRADING
HOST-SUFFIX,interactivebrokers.com,TRADING
HOST-SUFFIX,interactivebrokers.com.hk,TRADING
HOST-SUFFIX,interactivebrokers.ca,TRADING
HOST-SUFFIX,interactivebrokers.ie,TRADING
HOST-SUFFIX,interactivebrokers.co.uk,TRADING
HOST-SUFFIX,interactivebrokers.co.in,TRADING
HOST-SUFFIX,interactivebrokers.com.sg,TRADING
HOST-SUFFIX,interactivebrokers.com.au,TRADING
HOST-SUFFIX,ndcdyn.interactivebrokers.com,TRADING
HOST-SUFFIX,cdcdyn.interactivebrokers.com,TRADING

# thinkorswim / Schwab
HOST-SUFFIX,thinkorswim.com,TRADING
HOST-SUFFIX,tdameritrade.com,TRADING
HOST-SUFFIX,schwab.com,TRADING
HOST,tosmediaserver.schwab.com,TRADING
